{
  "manifest_version": 3,
  "name": "Icon!t",
  "version": "0.1.0",
  "description": "Insert custom icons next to key words in Twitter posts. Inspired by the 3D games from the hit franchize Super Mario.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_title": "Open Icon!t",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}